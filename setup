#!/usr/bin/env bash
set -euo pipefail

REPO_SSH="git@github.com:harshevo/Nvim-evo.git"
NVIM_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/nvim"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SCRIPTS_BIN="$HOME/.local/scripts"

UPDATE_MODE=0

usage() {
  cat <<EOF
Usage: setup [--update] [-h|--help]

  --update    Refresh installed packages and rewrite tracked configs
              (.tmux.conf, tmux-dev, shell rc blocks, terminal bindings,
              Nvim-evo repo, Node LTS) instead of skipping them.
  -h, --help  Show this help.
EOF
}

for arg in "$@"; do
  case "$arg" in
    --update)  UPDATE_MODE=1 ;;
    -h|--help) usage; exit 0 ;;
    *)         printf "Unknown argument: %s\n" "$arg" >&2; usage; exit 1 ;;
  esac
done

if [[ -t 1 ]]; then
  C_RESET=$'\033[0m'; C_BOLD=$'\033[1m'
  C_BLUE=$'\033[34m'; C_GREEN=$'\033[32m'
  C_YELLOW=$'\033[33m'; C_RED=$'\033[31m'; C_DIM=$'\033[2m'
else
  C_RESET=""; C_BOLD=""; C_BLUE=""; C_GREEN=""; C_YELLOW=""; C_RED=""; C_DIM=""
fi

log_step()  { printf "%s==>%s %s%s%s\n" "$C_BLUE"   "$C_RESET" "$C_BOLD" "$*" "$C_RESET"; }
log_ok()    { printf "  %s✔%s %s\n"     "$C_GREEN"  "$C_RESET" "$*"; }
log_skip()  { printf "  %s•%s %s%s%s\n" "$C_YELLOW" "$C_RESET" "$C_DIM" "$*" "$C_RESET"; }
log_info()  { printf "  %s…%s %s\n"     "$C_DIM"    "$C_RESET" "$*"; }
log_err()   { printf "  %s✘%s %s\n"     "$C_RED"    "$C_RESET" "$*" >&2; }

detect_os() {
  if [[ "$(uname -s)" == "Darwin" ]]; then
    echo "macos"
  elif [[ -f /etc/arch-release ]] || command -v pacman >/dev/null 2>&1; then
    echo "arch"
  elif [[ -f /etc/debian_version ]] || command -v apt-get >/dev/null 2>&1; then
    echo "debian"
  else
    echo "unknown"
  fi
}

bin_for_pkg() {
  local os="$1" pkg="$2"
  case "$pkg" in
    ripgrep)            echo "rg" ;;
    fd-find)            echo "fdfind" ;;
    neovim)             echo "nvim" ;;
    golang)             echo "go" ;;
    python3-pip)        echo "pip3" ;;
    python-pip)         echo "pip" ;;
    build-essential)    echo "gcc" ;;
    google-cloud-cli)   echo "gcloud" ;;
    postgresql@*)       echo "psql" ;;
    postgresql-client)  echo "psql" ;;
    postgresql)         echo "psql" ;;
    *)                  echo "$pkg" ;;
  esac
}

is_installed() {
  local os="$1" pkg="$2"
  local bin; bin=$(bin_for_pkg "$os" "$pkg")
  command -v "$bin" >/dev/null 2>&1 && return 0
  case "$os" in
    macos)  brew list --formula "$pkg" >/dev/null 2>&1 ;;
    debian) dpkg -s "$pkg" >/dev/null 2>&1 ;;
    arch)   pacman -Q "$pkg" >/dev/null 2>&1 ;;
    *)      return 1 ;;
  esac
}

needs_upgrade() {
  local os="$1" pkg="$2"
  case "$os" in
    macos)
      brew outdated --quiet "$pkg" 2>/dev/null | grep -qx "$pkg"
      ;;
    debian)
      apt list --upgradable 2>/dev/null | grep -q "^$pkg/"
      ;;
    arch)
      pacman -Qu "$pkg" 2>/dev/null | grep -q "^$pkg "
      ;;
    *)
      return 1
      ;;
  esac
}

installed_version() {
  local os="$1" pkg="$2"
  case "$os" in
    macos)  brew list --versions "$pkg" 2>/dev/null | awk '{print $2}' || true ;;
    debian) dpkg-query -W -f='${Version}' "$pkg" 2>/dev/null || true ;;
    arch)   pacman -Q "$pkg" 2>/dev/null | awk '{print $2}' || true ;;
  esac
  return 0
}

install_one() {
  local os="$1" pkg="$2"
  local bin; bin=$(bin_for_pkg "$os" "$pkg")

  if is_installed "$os" "$pkg"; then
    local ver; ver=$(installed_version "$os" "$pkg")
    if [[ "$UPDATE_MODE" == "1" ]]; then
      if needs_upgrade "$os" "$pkg"; then
        log_info "updating $pkg (installed: ${ver:-unknown})"
        case "$os" in
          macos)  brew upgrade "$pkg" || log_err "brew upgrade $pkg failed (continuing)" ;;
          debian) sudo apt-get install -y --only-upgrade "$pkg" ;;
          arch)   sudo pacman -S --needed --noconfirm "$pkg" ;;
        esac
      else
        log_skip "$pkg up to date (${ver:-installed})"
      fi
      return 0
    fi
    log_skip "$pkg already installed (${ver:-$(command -v "$bin" 2>/dev/null || echo present)})"
    return 0
  fi

  log_info "installing $pkg via $os package manager"
  case "$os" in
    macos)  brew install "$pkg" ;;
    debian) sudo apt-get install -y "$pkg" ;;
    arch)   sudo pacman -S --needed --noconfirm "$pkg" ;;
    *)      log_err "Unsupported OS for $pkg"; return 1 ;;
  esac
  log_ok "$pkg installed"
}

install_cask() {
  local cask="$1"
  local app_name="${2:-}"
  if brew list --cask "$cask" >/dev/null 2>&1; then
    local ver; ver=$(brew list --cask --versions "$cask" 2>/dev/null | awk '{print $2}' || true)
    if [[ "$UPDATE_MODE" == "1" ]]; then
      if brew outdated --cask --quiet "$cask" 2>/dev/null | grep -qx "$cask"; then
        log_info "updating cask $cask (installed: ${ver:-unknown})"
        brew upgrade --cask "$cask" || log_err "brew upgrade --cask $cask failed (continuing)"
      else
        log_skip "cask $cask up to date (${ver:-installed})"
      fi
      return 0
    fi
    log_skip "$cask already installed (${ver:-cask})"
    return 0
  fi
  if [[ -n "$app_name" ]] && \
     { [[ -d "/Applications/$app_name.app" ]] || [[ -d "$HOME/Applications/$app_name.app" ]]; }; then
    log_skip "$app_name.app present but not brew-managed — leaving as-is"
    return 0
  fi
  log_info "installing $cask via brew --cask"
  brew install --cask "$cask"
  log_ok "$cask installed"
}

install_vscode_debian() {
  if command -v code >/dev/null 2>&1; then
    log_skip "code already installed"; return 0
  fi
  log_info "adding Microsoft apt repo for VS Code"
  sudo apt-get install -y -qq wget gpg apt-transport-https
  wget -qO- https://packages.microsoft.com/keys/microsoft.asc \
    | sudo gpg --dearmor -o /usr/share/keyrings/packages.microsoft.gpg
  echo "deb [arch=amd64,arm64,armhf signed-by=/usr/share/keyrings/packages.microsoft.gpg] https://packages.microsoft.com/repos/code stable main" \
    | sudo tee /etc/apt/sources.list.d/vscode.list >/dev/null
  sudo apt-get update -qq
  sudo apt-get install -y code
  log_ok "VS Code installed"
}

install_dbeaver_debian() {
  if command -v dbeaver >/dev/null 2>&1 || [[ -d /usr/share/dbeaver-ce ]]; then
    log_skip "dbeaver already installed"; return 0
  fi
  log_info "adding DBeaver apt repo"
  sudo apt-get install -y -qq wget gpg apt-transport-https
  wget -qO- https://dbeaver.io/debs/dbeaver.gpg.key \
    | sudo gpg --dearmor -o /usr/share/keyrings/dbeaver.gpg
  echo "deb [signed-by=/usr/share/keyrings/dbeaver.gpg] https://dbeaver.io/debs/dbeaver-ce /" \
    | sudo tee /etc/apt/sources.list.d/dbeaver.list >/dev/null
  sudo apt-get update -qq
  sudo apt-get install -y dbeaver-ce
  log_ok "DBeaver installed"
}

install_gcloud_debian() {
  if command -v gcloud >/dev/null 2>&1; then
    log_skip "gcloud already installed"; return 0
  fi
  log_info "adding Google Cloud apt repo"
  sudo apt-get install -y -qq apt-transport-https ca-certificates gnupg curl
  curl -fsSL https://packages.cloud.google.com/apt/doc/apt-key.gpg \
    | sudo gpg --dearmor -o /usr/share/keyrings/cloud.google.gpg
  echo "deb [signed-by=/usr/share/keyrings/cloud.google.gpg] https://packages.cloud.google.com/apt cloud-sdk main" \
    | sudo tee /etc/apt/sources.list.d/google-cloud-sdk.list >/dev/null
  sudo apt-get update -qq
  sudo apt-get install -y google-cloud-cli
  log_ok "google-cloud-cli installed (run 'gcloud init' to authenticate)"
}

install_docker_debian() {
  if command -v docker >/dev/null 2>&1; then
    log_skip "docker already installed"; return 0
  fi
  log_info "adding Docker apt repo"
  sudo apt-get install -y -qq ca-certificates curl
  sudo install -m 0755 -d /etc/apt/keyrings
  local distro; distro=$(. /etc/os-release && echo "$ID")
  [[ "$distro" == "ubuntu" || "$distro" == "debian" ]] || distro="debian"
  curl -fsSL "https://download.docker.com/linux/$distro/gpg" \
    | sudo gpg --dearmor -o /etc/apt/keyrings/docker.gpg
  sudo chmod a+r /etc/apt/keyrings/docker.gpg
  local codename; codename=$(. /etc/os-release && echo "${VERSION_CODENAME:-${UBUNTU_CODENAME:-}}")
  echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/$distro $codename stable" \
    | sudo tee /etc/apt/sources.list.d/docker.list >/dev/null
  sudo apt-get update -qq
  sudo apt-get install -y docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin
  log_ok "Docker installed"
}

install_docker_post_linux() {
  command -v docker >/dev/null 2>&1 || return 0
  if ! getent group docker >/dev/null 2>&1; then
    sudo groupadd docker || true
  fi
  if ! id -nG "$USER" | tr ' ' '\n' | grep -qx docker; then
    log_info "adding $USER to docker group (log out/in to take effect)"
    sudo usermod -aG docker "$USER" || true
  else
    log_skip "$USER already in docker group"
  fi
  if command -v systemctl >/dev/null 2>&1; then
    sudo systemctl enable --now docker.service 2>/dev/null || true
    log_ok "docker.service enabled"
  fi
}

install_dev_apps() {
  local os="$1"
  log_step "Dev apps (git, VS Code, DBeaver, gcloud, Docker, Telegram)"
  install_one "$os" git

  case "$os" in
    macos)
      install_cask visual-studio-code "Visual Studio Code"
      install_cask dbeaver-community "DBeaver"
      install_cask google-cloud-sdk
      log_info "run 'gcloud init' after install"
      install_cask docker "Docker"
      log_info "launch Docker Desktop once to finish setup"
      install_cask telegram "Telegram"
      ;;
    debian)
      install_vscode_debian
      install_dbeaver_debian
      install_gcloud_debian
      install_docker_debian
      install_docker_post_linux
      install_one "$os" telegram-desktop
      ;;
    arch)
      install_one "$os" code
      if pacman -Si dbeaver >/dev/null 2>&1; then
        install_one "$os" dbeaver
      else
        log_skip "dbeaver not in official repos — install from AUR: yay -S dbeaver-ce"
      fi
      log_skip "google-cloud-cli not in official repos — install from AUR: yay -S google-cloud-cli"
      install_one "$os" docker
      install_one "$os" docker-compose
      install_docker_post_linux
      install_one "$os" telegram-desktop
      ;;
  esac
}

install_lang_tools() {
  local os="$1"
  log_step "Language toolchains (Python, C/C++, Go)"
  case "$os" in
    macos)
      install_one "$os" python
      install_one "$os" gcc
      install_one "$os" go
      if command -v clang >/dev/null 2>&1; then
        log_skip "clang already installed ($(command -v clang))"
      else
        log_info "clang missing — run: xcode-select --install"
      fi
      ;;
    debian)
      install_one "$os" python3
      install_one "$os" python3-pip
      install_one "$os" python3-venv
      install_one "$os" build-essential
      install_one "$os" clang
      install_one "$os" golang
      ;;
    arch)
      install_one "$os" python
      install_one "$os" python-pip
      install_one "$os" base-devel
      install_one "$os" clang
      install_one "$os" go
      ;;
  esac
}

install_postgres() {
  local os="$1"
  log_step "PostgreSQL + psql"
  case "$os" in
    macos)
      install_one "$os" postgresql@16
      if ! command -v psql >/dev/null 2>&1; then
        log_info "postgresql@16 is keg-only; add to PATH:"
        log_info '  echo '"'"'export PATH="/opt/homebrew/opt/postgresql@16/bin:$PATH"'"'"' >> ~/.zshrc'
        log_info "or run: brew link --force postgresql@16"
      fi
      ;;
    debian)
      install_one "$os" postgresql
      install_one "$os" postgresql-client
      ;;
    arch)
      install_one "$os" postgresql
      ;;
  esac
}

install_nvm_node() {
  log_step "nvm + Node.js LTS"
  export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
  if [[ -s "$NVM_DIR/nvm.sh" ]]; then
    log_skip "nvm already present at $NVM_DIR"
  else
    log_info "installing nvm"
    curl -fsSL https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.1/install.sh | bash
    log_ok "nvm installed"
  fi
  # shellcheck disable=SC1091
  [[ -s "$NVM_DIR/nvm.sh" ]] && \. "$NVM_DIR/nvm.sh"
  if ! command -v nvm >/dev/null 2>&1; then
    log_err "nvm not available in current shell; re-run after 'source $NVM_DIR/nvm.sh'"
    return 0
  fi
  if nvm current 2>/dev/null | grep -qE '^v[0-9]'; then
    if [[ "$UPDATE_MODE" == "1" ]]; then
      log_info "updating Node.js LTS"
      nvm install --lts --reinstall-packages-from=current >/dev/null 2>&1 || nvm install --lts
      nvm alias default 'lts/*' >/dev/null 2>&1 || true
      log_ok "Node now $(nvm current)"
    else
      log_skip "Node already installed via nvm ($(nvm current))"
    fi
  else
    log_info "installing Node.js LTS"
    nvm install --lts
    nvm alias default 'lts/*' >/dev/null 2>&1 || true
    log_ok "Node $(nvm current) installed"
  fi
}

ensure_pm_ready() {
  local os="$1"
  case "$os" in
    macos)
      if ! command -v brew >/dev/null 2>&1; then
        log_err "Homebrew not found. Install from https://brew.sh"
        exit 1
      fi
      if [[ "$UPDATE_MODE" == "1" ]]; then
        log_info "running brew update"
        brew update
      fi
      ;;
    debian)
      log_info "running apt-get update"
      sudo apt-get update -qq
      if [[ "$UPDATE_MODE" == "1" ]]; then
        log_info "running apt-get upgrade"
        sudo apt-get upgrade -y
      fi
      ;;
    arch)
      if [[ "$UPDATE_MODE" == "1" ]]; then
        log_info "running pacman -Syu"
        sudo pacman -Syu --noconfirm
      else
        log_info "syncing pacman databases"
        sudo pacman -Sy --noconfirm >/dev/null
      fi
      ;;
  esac
}

backup_if_present() {
  local path="$1"
  [[ -e "$path" || -L "$path" ]] || return 0
  local target="$path"
  if [[ -L "$path" ]]; then
    target=$(realpath -- "$path" 2>/dev/null \
      || readlink -f -- "$path" 2>/dev/null \
      || echo "$path")
  fi
  local ts; ts=$(date +%Y%m%d-%H%M%S)
  cp -a "$target" "$target.bak.$ts"
  log_info "backed up $target -> $target.bak.$ts"
}

install_tmux_conf() {
  log_step "tmux config (.tmux.conf)"
  local src="$SCRIPT_DIR/.tmux.conf"
  local dst="$HOME/.tmux.conf"
  if [[ ! -f "$src" ]]; then
    log_err "missing $src"; return 1
  fi
  if [[ -f "$dst" ]] && cmp -s "$src" "$dst"; then
    log_skip ".tmux.conf already up to date"
  else
    backup_if_present "$dst"
    cp "$src" "$dst"
    log_ok "installed $dst"
  fi

  local tpm_dir="$HOME/.tmux/plugins/tpm"
  if [[ ! -d "$tpm_dir" ]]; then
    log_info "cloning TPM (tmux plugin manager)"
    git clone --depth=1 https://github.com/tmux-plugins/tpm "$tpm_dir"
    log_ok "TPM installed (run prefix + I inside tmux to fetch plugins)"
  elif [[ "$UPDATE_MODE" == "1" && -d "$tpm_dir/.git" ]]; then
    log_info "updating TPM"
    git -C "$tpm_dir" pull --ff-only
    log_ok "TPM updated"
  else
    log_skip "TPM already present"
  fi
}

install_tmux_dev() {
  log_step "tmux-dev script"
  local src="$SCRIPT_DIR/tmux-dev"
  local dst="$SCRIPTS_BIN/tmux-dev"
  mkdir -p "$SCRIPTS_BIN"
  if [[ ! -f "$src" ]]; then
    log_err "missing $src"; return 1
  fi
  if [[ -f "$dst" ]] && cmp -s "$src" "$dst"; then
    log_skip "tmux-dev already up to date ($dst)"
  else
    backup_if_present "$dst"
    cp "$src" "$dst"
    chmod +x "$dst"
    log_ok "installed $dst"
  fi
}

clone_or_pull_nvim() {
  log_step "Nvim-evo config"
  if [[ -d "$NVIM_DIR/.git" ]]; then
    local origin
    origin=$(git -C "$NVIM_DIR" remote get-url origin 2>/dev/null || echo "")
    log_info "existing repo at $NVIM_DIR (origin: $origin)"
    git -C "$NVIM_DIR" pull --ff-only
    log_ok "Nvim-evo updated"
  elif [[ -e "$NVIM_DIR" ]]; then
    log_err "$NVIM_DIR exists but is not a git repo. Aborting to avoid data loss."
    exit 1
  else
    log_info "cloning $REPO_SSH -> $NVIM_DIR"
    mkdir -p "$(dirname "$NVIM_DIR")"
    git clone "$REPO_SSH" "$NVIM_DIR"
    log_ok "Nvim-evo cloned"
  fi
}

pick_rc() {
  if [[ "${SHELL:-}" == *"zsh"* ]]; then
    echo "$HOME/.zshrc"
  else
    echo "$HOME/.bashrc"
  fi
}

install_block() {
  local rc="$1" marker="$2" end_marker="$3" body="$4"
  if [[ -f "$rc" ]] && grep -qF "$marker" "$rc"; then
    if [[ "$UPDATE_MODE" == "1" ]]; then
      backup_if_present "$rc"
      awk -v s="$marker" -v e="$end_marker" '
        $0 == s {skip=1; next}
        skip && $0 == e {skip=0; next}
        !skip
      ' "$rc" > "$rc.tmp" && mv "$rc.tmp" "$rc"
      log_info "removed old '$marker' block from $rc"
    else
      log_skip "'$marker' already present in $rc"
      return
    fi
  fi
  printf '\n%s\n%s\n%s\n' "$marker" "$body" "$end_marker" >> "$rc"
  log_ok "appended block to $rc"
}

install_path_exports() {
  log_step "PATH exports"
  local rc; rc=$(pick_rc)
  local marker="# >>> setup-env PATH >>>"
  local end_marker="# <<< setup-env PATH <<<"
  local body
  body=$(cat <<'EOF'
export PATH="$HOME/.local/bin:$HOME/.local/scripts:$PATH"
EOF
)
  install_block "$rc" "$marker" "$end_marker" "$body"
}

install_sd_function() {
  log_step "sd() shell function"
  local rc; rc=$(pick_rc)
  local marker="# >>> sd() fzf directory jumper >>>"
  local end_marker="# <<< sd() fzf directory jumper <<<"
  local body
  body=$(cat <<'EOF'
sd() {
  local dir
  dir=$(fd --type d --hidden --exclude .git . "${1:-$HOME}" 2>/dev/null | fzf --prompt="cd> ") || return
  cd "$dir"
}
EOF
)
  install_block "$rc" "$marker" "$end_marker" "$body"
}

install_ctrl_f_binding() {
  log_step "Ctrl+F tmux-dev keybinding (shell)"
  local rc; rc=$(pick_rc)
  if [[ "$rc" != *".zshrc" ]]; then
    log_skip "non-zsh shell ($rc) — bind Ctrl+F manually to run tmux-dev"
    return
  fi
  local marker="# >>> Ctrl+F tmux-dev launcher >>>"
  local end_marker="# <<< Ctrl+F tmux-dev launcher <<<"
  local body
  body=$(cat <<'EOF'
_tmux_dev_widget() {
  if [[ -n "${TMUX:-}" ]]; then
    zle -M "Already inside tmux"
    return
  fi
  BUFFER="tmux-dev ."
  zle accept-line
}
zle -N _tmux_dev_widget
bindkey '^F' _tmux_dev_widget
EOF
)
  install_block "$rc" "$marker" "$end_marker" "$body"
}

install_iterm2_binding() {
  log_step "iTerm2 Ctrl+F binding"
  if [[ "$(uname -s)" != "Darwin" ]]; then
    log_skip "not macOS, skipping iTerm2"
    return
  fi
  if [[ ! -d "/Applications/iTerm.app" && ! -d "$HOME/Applications/iTerm.app" ]]; then
    log_skip "iTerm.app not installed"
    return
  fi

  local plist="$HOME/Library/Preferences/com.googlecode.iterm2.plist"
  if [[ ! -f "$plist" ]]; then
    log_skip "iTerm2 plist not found (launch iTerm2 once, then re-run setup)"
    return
  fi

  local pb=/usr/libexec/PlistBuddy
  local key="0x66-0x40000"

  if "$pb" -c "Print :GlobalKeyMap:$key" "$plist" >/dev/null 2>&1; then
    if [[ "$UPDATE_MODE" != "1" ]]; then
      log_skip "iTerm2 Ctrl+F binding already present"
      return
    fi
    log_info "rewriting iTerm2 Ctrl+F binding"
  fi

  backup_if_present "$plist"

  "$pb" -c "Print :GlobalKeyMap" "$plist" >/dev/null 2>&1 || \
    "$pb" -c "Add :GlobalKeyMap dict" "$plist"

  "$pb" -c "Delete :GlobalKeyMap:$key" "$plist" 2>/dev/null || true
  "$pb" -c "Add :GlobalKeyMap:$key dict" "$plist"
  "$pb" -c "Add :GlobalKeyMap:$key:Action integer 25" "$plist"
  "$pb" -c "Add :GlobalKeyMap:$key:Text string tmux-dev .\\n" "$plist"
  "$pb" -c "Add :GlobalKeyMap:$key:Version integer 1" "$plist"

  killall cfprefsd 2>/dev/null || true
  log_ok "iTerm2 Ctrl+F → 'tmux-dev .' (restart iTerm2 to apply)"
}

print_terminal_app_note() {
  log_step "Terminal.app Ctrl+F"
  if [[ "$(uname -s)" != "Darwin" ]]; then
    log_skip "not macOS, skipping Terminal.app"
    return
  fi
  log_info "Terminal.app passes Ctrl+F through to the shell,"
  log_info "so the zsh widget above already handles it."
  log_info "For a terminal-level binding: Terminal → Settings → Profiles → Keyboard,"
  log_info "add: key ^F, action 'Send Text', text: tmux-dev .\\n"
}

install_alacritty_binding() {
  log_step "Alacritty Ctrl+F binding"
  local cfg_dir="$HOME/.config/alacritty"
  local toml="$cfg_dir/alacritty.toml"
  local yml="$cfg_dir/alacritty.yml"

  if [[ -f "$yml" && ! -f "$toml" ]]; then
    log_skip "alacritty.yml exists — add binding manually (this script only writes TOML)"
    return
  fi

  mkdir -p "$cfg_dir"
  local marker="# >>> setup-env Ctrl+F tmux-dev >>>"
  local end_marker="# <<< setup-env Ctrl+F tmux-dev <<<"

  if [[ -f "$toml" ]] && grep -qF "$marker" "$toml"; then
    if [[ "$UPDATE_MODE" == "1" ]]; then
      backup_if_present "$toml"
      awk -v s="$marker" -v e="$end_marker" '
        $0 == s {skip=1; next}
        skip && $0 == e {skip=0; next}
        !skip
      ' "$toml" > "$toml.tmp" && mv "$toml.tmp" "$toml"
      log_info "removed old Alacritty binding from $toml"
    else
      log_skip "Alacritty binding already present in $toml"
      return
    fi
  fi

  cat >> "$toml" <<EOF

$marker
[[keyboard.bindings]]
key = "F"
mods = "Control"
chars = "tmux-dev .\\n"
$end_marker
EOF
  log_ok "appended Ctrl+F binding to $toml"
}

main() {
  local os
  os=$(detect_os)

  log_step "Environment"
  log_info "OS: $os"
  log_info "Shell: ${SHELL:-unknown}"
  log_info "Setup dir: $SCRIPT_DIR"
  log_info "Nvim config: $NVIM_DIR"
  log_info "Mode: $([[ "$UPDATE_MODE" == "1" ]] && echo "update" || echo "install")"

  if [[ "$os" == "unknown" ]]; then
    log_err "Unsupported OS. Aborting."
    exit 1
  fi

  log_step "Package manager"
  ensure_pm_ready "$os"

  local fd_pkg="fd-find"
  if [[ "$os" == "macos" || "$os" == "arch" ]]; then
    fd_pkg="fd"
  fi

  log_step "Installing tools"
  install_one "$os" fzf
  install_one "$os" "$fd_pkg"
  install_one "$os" ripgrep
  install_one "$os" tmux
  install_one "$os" neovim

  if [[ "$os" == "debian" ]] && ! command -v fd >/dev/null 2>&1 && command -v fdfind >/dev/null 2>&1; then
    mkdir -p "$HOME/.local/bin"
    ln -sf "$(command -v fdfind)" "$HOME/.local/bin/fd"
    log_ok "linked fdfind -> ~/.local/bin/fd (ensure ~/.local/bin is on PATH)"
  fi

  install_dev_apps "$os"
  install_lang_tools "$os"
  install_postgres "$os"
  install_nvm_node

  install_tmux_conf
  install_tmux_dev
  clone_or_pull_nvim
  install_path_exports
  install_sd_function
  install_ctrl_f_binding
  install_iterm2_binding
  print_terminal_app_note
  install_alacritty_binding

  log_step "Summary"
  for b in fzf fd rg tmux nvim git code dbeaver gcloud docker python3 pip3 gcc clang go node psql; do
    if command -v "$b" >/dev/null 2>&1; then
      log_ok "$b -> $(command -v "$b")"
    else
      log_err "$b not on PATH"
    fi
  done

  printf "\n%sDone.%s Open a new shell or 'source' your rc file to use sd() and Ctrl+F.\n" "$C_BOLD" "$C_RESET"
}

main "$@"
